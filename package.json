{
  "name": "claude-ding",
  "version": "0.1.0",
  "description": "Sonic feedback for Claude Code — gaming-inspired sounds, TTS, and audio workflows",
  "author": "Austin <austin@austn.net>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "claude-ding": "./dist/cli.js",
    "cding": "./dist/cli.js"
  },
  "files": [
    "dist",
    "sounds",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "notifications",
    "sounds",
    "tts",
    "hooks",
    "developer-tools",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
